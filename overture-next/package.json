{
  "name": "@overture/tool",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Active Overture Schwung tool source.",
  "scripts": {
    "build": "scripts/build.sh",
    "deploy": "scripts/deploy.sh",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "test": "vitest run",
    "lint:rules": "node scripts/test-state-ownership-rule.mjs && node scripts/test-internal-privacy-rules.mjs && node scripts/check-internal-module-contracts.mjs",
    "lint:arch": "depcruise -c .dependency-cruiser.cjs src ui",
    "typecheck": "tsc -p tsconfig.json",
    "verify": "pnpm typecheck && pnpm lint && pnpm lint:rules && pnpm test && pnpm lint:arch"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/rule-tester": "^8.62.0",
    "dependency-cruiser": "17.4.3",
    "esbuild": "0.21.5",
    "eslint": "^9.39.4",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.1.9"
  }
}
