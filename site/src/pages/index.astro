---
import "../styles/global.css";

const pageTitle = "Overture | Hybrid groovebox for Ableton Move";
const pageDescription =
  "Overture is a hybrid groovebox for Ableton Move, combining four Ableton tracks with four open Schwung tracks.";
const pageUrl = "https://overture.mov/";
const socialImage = "https://overture.mov/images/og-image.png";

const productPoints = [
  {
    label: "Tracks",
    value: "8 total",
    body: "Four Ableton tracks and four Schwung tracks share one performance surface.",
  },
  {
    label: "Engines",
    value: "4 + 4",
    body: "Native Move engines stay close; Schwung modules extend the palette.",
  },
  {
    label: "Workflow",
    value: "Move-first",
    body: "Direct, compact, and built for decisions in the moment.",
  },
];

const statusItems = [
  {
    label: "Ableton",
    value: "4 tracks",
  },
  {
    label: "Schwung",
    value: "4 tracks",
  },
  {
    label: "Status",
    value: "Coming soon",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={pageUrl} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Overture" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Overture waveform and encoder visual." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImage} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header" aria-label="Primary navigation">
      <a class="brand" href={import.meta.env.BASE_URL} aria-label="Overture home">
        <span class="brand-mark" aria-hidden="true">O</span>
        <span>Overture</span>
      </a>
      <a class="github-link" href="https://github.com/m-dwyer/overture">GitHub</a>
    </header>

    <main>
      <section class="hero">
        <div class="hero-display" aria-hidden="true">
          <canvas data-overture-waveform></canvas>
        </div>
        <div class="hero-copy">
          <p class="eyebrow">Coming soon for Ableton Move</p>
          <h1>Overture</h1>
          <p class="lede">
            A minimal hybrid groovebox: four Ableton tracks, four Schwung tracks, one focused performance instrument.
          </p>
        </div>
      </section>

      <section id="tracks" class="spec-section" aria-label="Overture track architecture">
        <div class="section-copy">
          <p class="eyebrow">Architecture</p>
          <h2>One instrument. Two track worlds.</h2>
          <p>
            Overture keeps the track model simple: the first four tracks stay close to Move's native engines, while the second four open the door to Schwung modules.
          </p>
        </div>
        <dl class="spec-list">
          {statusItems.map((item) => (
            <div>
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section id="instrument" class="spec-section">
        <div class="section-copy">
          <p class="eyebrow">Instrument</p>
          <h2>Designed for hardware decisions.</h2>
          <p>
            Overture augments the Move instead of turning it into a generic controller. Native Ableton engines and open Schwung modules share timing, clips, track movement, and performance gestures.
          </p>
        </div>
        <div class="detail-list" aria-label="Overture design principles">
          {productPoints.map((point) => (
            <article>
              <span>{point.label}</span>
              <strong>{point.value}</strong>
              <p>{point.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="soon" class="closing-section">
        <p class="eyebrow">Coming soon</p>
        <p>
          Overture is in active development as a polished, minimal groovebox layer for Ableton Move.
        </p>
      </section>
    </main>

    <footer>
      <span>Overture</span>
      <span>Built on Schwung and dAVEBOx.</span>
    </footer>
    <script>
      import "../scripts/overture-waveform";
    </script>
  </body>
</html>
