---
import "../styles/global.css";

const pageTitle = "Overture | Experimental dAVEBOx fork for Ableton Move";
const pageDescription =
  "Overture is an experimental dAVEBOx fork built on Schwung, exploring a hybrid groovebox workflow for Ableton Move.";
const pageUrl = "https://overture.mov/";
const socialImage = "https://overture.mov/images/og-image.png";
const baseUrl = import.meta.env.BASE_URL;

const productPoints = [
  {
    label: "Tracks",
    value: "8 total",
    body: "Four Ableton tracks and four Schwung tracks share one experimental performance surface.",
  },
  {
    label: "Engines",
    value: "4 + 4",
    body: "Native Move engines stay close; Schwung modules extend the palette.",
  },
  {
    label: "Workflow",
    value: "Move-first",
    body: "Direct, compact, and built for decisions on Move hardware.",
  },
];

const statusItems = [
  {
    label: "Lineage",
    value: "dAVEBOx fork",
  },
  {
    label: "Ableton",
    value: "4 tracks",
  },
  {
    label: "Schwung",
    value: "4 tracks",
  },
  {
    label: "Status",
    value: "Coming soon",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={pageUrl} />
    <link rel="icon" href={`${baseUrl}favicon.svg`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Overture" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Overture waveform and encoder visual." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImage} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header" aria-label="Primary navigation">
      <a class="brand" href={baseUrl} aria-label="Overture home">
        <span class="brand-mark" aria-hidden="true">O</span>
        <span>Overture</span>
      </a>
      <nav class="header-links" aria-label="Links">
        <a class="github-link" href={`${baseUrl}try/`}>Try</a>
        <a class="github-link" href="https://github.com/m-dwyer/overture">GitHub</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-display" aria-hidden="true">
          <img
            class="waveform-fallback"
            src={`${baseUrl}images/og-image.png`}
            alt=""
            loading="eager"
            decoding="async"
          />
          <canvas data-overture-waveform></canvas>
        </div>
        <div class="hero-copy">
          <p class="eyebrow">Experimental dAVEBOx fork for Ableton Move</p>
          <h1>Overture</h1>
          <p class="lede">
            A derivative groovebox experiment built on dAVEBOx and Schwung, exploring a hybrid Move-native + Schwung workflow.
          </p>
          <a class="primary-link" href={`${baseUrl}try/`}>Try the emulator</a>
        </div>
      </section>

      <section id="lineage" class="spec-section" aria-label="Overture upstream lineage">
        <div class="section-copy">
          <p class="eyebrow">Lineage</p>
          <h2>Upstream foundation.</h2>
          <p>
            Overture is an experimental fork of
            <a class="text-link" href="https://github.com/legsmechanical/schwung-davebox">dAVEBOx</a>,
            built on
            <a class="text-link" href="https://github.com/charlesvestal/schwung">Schwung</a>.
            dAVEBOx and Schwung provide the foundation: the Move tool lineage, Schwung runtime,
            sequencing surface, and much of the underlying behaviour.
          </p>
        </div>
        <div class="detail-list" aria-label="Upstream project credits">
          <article>
            <span>Upstream</span>
            <strong>dAVEBOx</strong>
            <p>The source project and community foundation for Overture's sequencer and Move-facing workflow.</p>
          </article>
          <article>
            <span>Runtime</span>
            <strong>Schwung</strong>
            <p>The Move module runtime and open-engine ecosystem that Overture bundles and extends.</p>
          </article>
          <article>
            <span>Position</span>
            <strong>Derivative</strong>
            <p>Overture explores an opinionated direction on top of that foundation, not a from-scratch replacement.</p>
          </article>
        </div>
      </section>

      <section id="tracks" class="spec-section" aria-label="Overture track architecture">
        <div class="section-copy">
          <p class="eyebrow">Architecture</p>
          <h2>One instrument. Two track worlds.</h2>
          <p>
            Overture keeps the track model simple: the first four tracks stay close to Move's native engines, while the second four open the door to Schwung modules.
          </p>
        </div>
        <dl class="spec-list">
          {statusItems.map((item) => (
            <div>
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section id="instrument" class="spec-section">
        <div class="section-copy">
          <p class="eyebrow">Instrument</p>
          <h2>Designed for hardware decisions.</h2>
          <p>
            Overture explores ways to augment the Move instead of turning it into a generic controller. Native Ableton engines and open Schwung modules share timing, clips, track movement, and performance gestures.
          </p>
        </div>
        <div class="detail-list" aria-label="Overture design principles">
          {productPoints.map((point) => (
            <article>
              <span>{point.label}</span>
              <strong>{point.value}</strong>
              <p>{point.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="soon" class="closing-section">
        <p class="eyebrow">Coming soon</p>
        <p>
          Overture is in active development as a focused groovebox layer for Ableton Move.
        </p>
      </section>
    </main>

    <footer>
      <span>Overture</span>
      <span>
        Experimental fork of
        <a href="https://github.com/legsmechanical/schwung-davebox">dAVEBOx</a>,
        built on
        <a href="https://github.com/charlesvestal/schwung">Schwung</a>.
      </span>
    </footer>
    <script>
      import "../scripts/overture-waveform";
    </script>
  </body>
</html>
