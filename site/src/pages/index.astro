---
import "../styles/global.css";

const trackGroups = [
  {
    label: "Ableton",
    count: "4",
    body: "Native Move tracks for the core of the set.",
  },
  {
    label: "Schwung",
    count: "4",
    body: "Open tracks for custom synths, effects, and experiments.",
  },
];

const productPoints = [
  {
    label: "01",
    title: "Eight tracks",
    body: "Four Ableton tracks and four Schwung tracks share one performance surface.",
  },
  {
    label: "02",
    title: "Move-first",
    body: "The workflow stays close to the hardware: direct, compact, and built for decisions in the moment.",
  },
  {
    label: "03",
    title: "Open engine",
    body: "Schwung modules extend the sound palette without breaking the groovebox model.",
  },
];

const statusItems = [
  "Built for Ableton Move",
  "8-track architecture: 4 Ableton, 4 Schwung",
  "Minimal performance interface",
  "Coming soon",
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Overture is a hybrid groovebox for Ableton Move, combining four Ableton tracks with four open Schwung tracks."
    />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>Overture | Hybrid groovebox for Ableton Move</title>
  </head>
  <body>
    <header class="site-header" aria-label="Primary navigation">
      <a class="brand" href={import.meta.env.BASE_URL} aria-label="Overture home">
        <span class="brand-mark" aria-hidden="true">O</span>
        <span>Overture</span>
      </a>
      <a class="github-link" href="https://github.com/m-dwyer/overture">GitHub</a>
    </header>

    <main>
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Coming soon for Ableton Move</p>
          <h1>Overture</h1>
          <p class="lede">
            A minimal hybrid groovebox: four Ableton tracks, four Schwung tracks, one focused performance instrument.
          </p>
        </div>
      </section>

      <section id="tracks" class="track-section" aria-label="Overture track architecture">
        <div class="track-head">
          <p class="eyebrow">8 tracks</p>
          <h2>A hybrid set that still feels like one instrument.</h2>
          <p>
            Overture keeps the track model simple: the first four tracks stay close to Move's native engines, while the second four open the door to Schwung modules.
          </p>
        </div>
        <div class="track-cards">
          {trackGroups.map((group) => (
            <article>
              <span>{group.label}</span>
              <strong>{group.count}</strong>
              <p>{group.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="instrument" class="section split-section">
        <div class="section-copy">
          <p class="eyebrow">Instrument</p>
          <h2>Designed for hardware decisions.</h2>
          <p>
            Overture augments the Move instead of turning it into a generic controller. Native Ableton engines and open Schwung modules share timing, clips, track movement, and performance gestures.
          </p>
        </div>
        <div class="point-stack">
          {productPoints.map((point) => (
            <article class="point">
              <span>{point.label}</span>
              <h3>{point.title}</h3>
              <p>{point.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section feature-band" aria-label="Overture feature highlights">
        <div>
          <span class="feature-label">4 Ableton</span>
          <p>Keep Move's native engines ready for the core parts of a set.</p>
        </div>
        <div>
          <span class="feature-label">4 Schwung</span>
          <p>Add open DSP tracks without leaving the same performance surface.</p>
        </div>
        <div>
          <span class="feature-label">1 instrument</span>
          <p>Sequence, edit, and perform both sides with one compact mental model.</p>
        </div>
      </section>

      <section id="soon" class="section status-panel">
        <div>
          <p class="eyebrow">Coming soon</p>
          <h2>A new performance instrument for Move is taking shape.</h2>
          <p>
            Overture is in active development as a polished, minimal groovebox layer for Ableton Move. The public launch page is here first; the instrument follows.
          </p>
        </div>
        <ul class="status-list">
          {statusItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>
    </main>

    <footer>
      <span>Overture</span>
      <span>Built on Schwung and dAVEBOx.</span>
    </footer>
  </body>
</html>
