{
  "name": "overture-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Overture emulator — runs the real tool UI against a browser mock of the Schwung host (UX-iteration harness).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p ../overture-next/tsconfig.json",
    "depcruise": "pnpm -C ../overture-ui exec depcruise -c ../overture-next/.dependency-cruiser.cjs ../overture-next/src ../overture-next/ui",
    "verify": "pnpm typecheck && pnpm depcruise && pnpm test:node tests/overture-next/core.test.ts",
    "test:node": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test tests/render.spec.ts tests/inputs.spec.ts",
    "test:e2e:reference": "playwright test",
    "manual:generate": "MANUAL_GENERATE=1 playwright test tests/manual-shots.spec.ts",
    "reference:generate": "REFERENCE_GENERATE=1 playwright test tests/manual-reference.spec.ts",
    "manual:assert": "playwright test tests/manual-assertions.spec.ts",
    "manual:check": "pnpm manual:generate && pnpm reference:generate && pnpm manual:assert"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "2.1.9",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.15",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.46.4",
    "unified": "^11.0.5",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.1"
  }
}
